{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/voxsentry/artifact.schema.json",
  "title": "VoxSentry Artifact",
  "type": "object",
  "required": ["metadata", "transcription", "translation", "semantic_analysis"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["source_file", "processing_timestamp", "detected_language", "translation_language"],
      "properties": {
        "source_file": { "type": "string", "minLength": 1 },
        "processing_timestamp": { "type": "string", "format": "date-time" },
        "detected_language": { "type": "string", "minLength": 2 },
        "translation_language": { "type": "string", "minLength": 2 }
      },
      "additionalProperties": true
    },
    "transcription": {
      "type": "object",
      "required": ["original_text"],
      "properties": {
        "original_text": { "type": "string" },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "translation": {
      "type": "object",
      "required": ["translated_text"],
      "properties": {
        "translated_text": { "type": "string" },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "semantic_analysis": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entity", "type"],
            "properties": {
              "entity": { "type": "string" },
              "type": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "sentiment_score": { "type": "number", "minimum": -1, "maximum": 1 },
        "topics": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}